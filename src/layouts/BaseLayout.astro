---
import BaseHead from "../components/BaseHead.astro";
import Sidebar from "../components/Sidebar.astro";
import ChatWidget from "../components/ChatWidget.astro";
import { SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
  jsonLd?: Record<string, unknown>;
}
const { title = SITE_TITLE, description, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} jsonLd={jsonLd} />
  </head>
  <body>
    <div class="shell">
      <Sidebar />
      <main class="content">
        <slot />
      </main>
    </div>
    <ChatWidget />
  </body>
</html>
