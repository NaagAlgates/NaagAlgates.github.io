---
interface Props {
  date: Date;
  /** "dot" -> 2023.05.01 (mono list style); "long" -> 1 May 2023 */
  variant?: "dot" | "long";
}
const { date, variant = "long" } = Astro.props;

const iso = date.toISOString().slice(0, 10);
const display =
  variant === "dot"
    ? iso.replace(/-/g, ".")
    : date.toLocaleDateString("en-AU", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });
---

<time datetime={iso}>{display}</time>
