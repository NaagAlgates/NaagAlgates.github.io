---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const t = encodeURIComponent(title);
const u = encodeURIComponent(url);

const targets = [
  { name: "X", href: `https://twitter.com/intent/tweet?text=${t}&url=${u}` },
  { name: "LinkedIn", href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}` },
  { name: "Bluesky", href: `https://bsky.app/intent/compose?text=${t}%20${u}` },
  { name: "Facebook", href: `https://www.facebook.com/sharer/sharer.php?u=${u}` },
  { name: "WhatsApp", href: `https://wa.me/?text=${t}%20${u}` },
  { name: "Reddit", href: `https://www.reddit.com/submit?url=${u}&title=${t}` },
  { name: "Email", href: `mailto:?subject=${t}&body=${u}` },
];

// Brand glyph paths (single-path icons keep the markup small).
const icons: Record<string, string> = {
  X: "M18.9 1.2h3.7l-8 9.2 9.5 12.5h-7.4l-5.8-7.6-6.7 7.6H.4l8.6-9.8L0 1.2h7.6l5.2 6.9zM17.6 21h2L6.5 3.3H4.3z",
  LinkedIn: "M20.4 20.4h-3.5v-5.6c0-1.3 0-3-1.9-3s-2.1 1.4-2.1 2.9v5.7H9.4V9h3.3v1.5h.1c.5-.9 1.6-1.9 3.3-1.9 3.5 0 4.2 2.3 4.2 5.4zM5.3 7.4a2 2 0 110-4.1 2 2 0 010 4.1zM7.1 20.4H3.6V9h3.5z",
  Bluesky: "M5.8 3.4C8.6 5.5 11.6 9.8 12 12c.4-2.2 3.4-6.5 6.2-8.6 2-1.5 5.3-2.7 5.3 1.1 0 .8-.4 6.4-.7 7.3-.8 3.1-4 3.9-6.8 3.4 4.9.8 6.1 3.6 3.4 6.3-5 5.1-7.2-1.3-7.8-2.9-.1-.3-.2-.5-.2-.3 0-.2-.1 0-.2.3-.6 1.6-2.8 8-7.8 2.9-2.7-2.7-1.5-5.5 3.4-6.3-2.8.5-6-.3-6.8-3.4C.3 11 0 5.3 0 4.5 0 .7 3.3 1.9 5.3 3.4z",
  Facebook: "M14 13.5h2.5l1-4H14V7c0-1 .5-2 2-2h1.5V1.6c-.3 0-1.4-.1-2.6-.1-2.7 0-4.4 1.6-4.4 4.6v2.4H7v4h3.5V24H14z",
  WhatsApp: "M.1 24l1.7-6.2a11.9 11.9 0 1110.3 6h-.1a12 12 0 01-5.7-1.5zm6.6-3.8l.4.2a9.9 9.9 0 005 1.4 9.9 9.9 0 10-9.9-9.9c0 1.9.5 3.7 1.5 5.3l.2.4-1 3.7zm11.6-5.7c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a8 8 0 01-2.4-1.5 9 9 0 01-1.6-2c-.2-.3 0-.4.1-.6l.5-.5c.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5L11 7.4c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.5 0-.7.3-.2.3-.9.9-.9 2.2s1 2.6 1.1 2.7c.1.2 2 3 4.7 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.5-.6 1.8-1.3.2-.6.2-1.2.1-1.3 0-.1-.2-.2-.4-.3z",
  Reddit: "M22 12a2.2 2.2 0 00-3.7-1.6 10.8 10.8 0 00-5.8-1.8l1-4.6 3.2.7a1.6 1.6 0 101.6-1.7 1.6 1.6 0 00-1.4.9l-3.6-.8-1.1 5.3a10.8 10.8 0 00-5.9 1.8A2.2 2.2 0 102 12a4.3 4.3 0 000 .7c0 3.4 3.9 6.1 8.8 6.1s8.8-2.7 8.8-6.1a4.3 4.3 0 000-.7zm-14 1.6a1.6 1.6 0 113.2 0 1.6 1.6 0 01-3.2 0zm8.9 4.3c-1.1 1.1-3.3 1.2-3.9 1.2s-2.8-.1-3.9-1.2a.4.4 0 01.6-.6c.7.7 2.2.9 3.3.9s2.6-.2 3.3-.9a.4.4 0 11.6.6zm-.3-2.7a1.6 1.6 0 110-3.2 1.6 1.6 0 010 3.2z",
  Email: "M2 4h20v16H2zm2 2v.5l8 5 8-5V6l-8 5z",
};
---

<div class="post-actions" data-share data-url={url} data-title={title}>
  <span class="lbl mono">share:</span>

  <button class="post-action" type="button" data-copy aria-label="Copy link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" data-copy-icon>
      <path d="M10 13a5 5 0 007 0l3-3a5 5 0 00-7-7l-1 1"></path>
      <path d="M14 11a5 5 0 00-7 0l-3 3a5 5 0 007 7l1-1"></path>
    </svg>
    <span data-copy-text>copy link</span>
  </button>

  {
    targets.map((s) => (
      <a
        class="post-action"
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Share on ${s.name}`}
        title={`Share on ${s.name}`}
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={icons[s.name]} />
        </svg>
      </a>
    ))
  }

  <button class="post-action" type="button" data-native hidden aria-label="More sharing options" title="More…">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle>
      <path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"></path>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-share]").forEach((root) => {
    const url = new URL(root.dataset.url!, location.href).href;
    const title = root.dataset.title || document.title;

    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    const copyText = root.querySelector<HTMLElement>("[data-copy-text]");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(url);
        copyBtn.classList.add("copied");
        if (copyText) copyText.textContent = "link copied!";
        setTimeout(() => {
          copyBtn.classList.remove("copied");
          if (copyText) copyText.textContent = "copy link";
        }, 2000);
      } catch {
        /* clipboard blocked — ignore */
      }
    });

    const nativeBtn = root.querySelector<HTMLButtonElement>("[data-native]");
    if (nativeBtn && typeof navigator.share === "function") {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener("click", () => {
        navigator.share({ title, url }).catch(() => {});
      });
    }
  });
</script>
