---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Share from "../../components/Share.astro";
import {
  SITE_TITLE,
  SITE_URL,
  AUTHOR,
  AUTHOR_URL,
  AUTHOR_SAMEAS,
  OG_DEFAULT_IMAGE,
  tagSlug,
} from "../../consts";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { Content } = await render(post);
// Trailing-slash form to match the canonical + sitemap URLs (no redirect hop).
const url = new URL(`/blog/${post.id}/`, SITE_URL).href;
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = post.data.updatedDate?.toISOString();
const ogImage = new URL(post.data.image ?? OG_DEFAULT_IMAGE, SITE_URL).href;
const author = {
  "@type": "Person",
  name: AUTHOR,
  url: AUTHOR_URL,
  sameAs: AUTHOR_SAMEAS,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedTime,
  ...(modifiedTime ? { dateModified: modifiedTime } : {}),
  keywords: post.data.tags.join(", "),
  inLanguage: "en",
  url,
  image: ogImage,
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  author,
  publisher: author,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  jsonLd={jsonLd}
  type="article"
  image={post.data.image}
  publishedTime={publishedTime}
  tags={post.data.tags}
>
  <article>
    <header class="article-header">
      <p class="meta mono">
        <FormattedDate date={post.data.pubDate} variant="long" /> · by {AUTHOR} ·
        ✍ human-written
      </p>
      <h1>{post.data.title}</h1>
      {
        post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((t) => (
              <a class="tag" href={`/tags/${tagSlug(t)}`}>
                {t.toLowerCase()}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <Share title={post.data.title} url={url} />

    <div class="prose">
      <Content />
    </div>

    <a class="back-link" href="/">← all posts</a>
  </article>
</BaseLayout>
