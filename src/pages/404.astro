---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — not found">
  <section class="intro" style="margin-top:48px;">
    <p class="prompt mono">~ $ cat page<span class="blink">▋</span></p>
    <h1 class="mono" style="font-size:clamp(30px,6vw,44px);">404<span class="tld"
      >: not found</span
    ></h1>
    <p class="bio">That page doesn't exist. It may have moved, or never did.</p>
    <div class="links"><a href="/">← back home</a></div>
  </section>
</BaseLayout>
